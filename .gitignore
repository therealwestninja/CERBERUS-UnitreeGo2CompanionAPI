# CERBERUS — .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/
share/python-wheels/
*.pth
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.env.local

# Keep .env.example, ignore .env
.env
!.env.example

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover
nosetests.xml
test-results/

# Linting
.ruff_cache/
.mypy_cache/
.dmypy.json

# CERBERUS runtime
logs/
*.ndjson
*.ndjson.gz
cerberus_personality.json
data/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Docker
.dockerignore

# Docs build
docs/_build/
docs/site/

# Models / weights (large binary files)
*.pt
*.pth
*.onnx
*.tflite
*.pkl

# ROS2 build artefacts
install/
log/
devel/

# Jupyter
*.ipynb
.ipynb_checkpoints/
