# CERBERUS — .env.example
# Copy to .env and fill in your values.
# These override config/cerberus.yaml when set.

# Robot
GO2_IP=192.168.123.1
GO2_SIMULATION=false

# API server
GO2_API_HOST=0.0.0.0
GO2_API_PORT=8080

# Buttplug / Intiface
INTIFACE_URL=ws://127.0.0.1:12345

# Hismith BLE (optional — leave blank to auto-scan)
HISMITH_ADDRESS=

# Galaxy Fit 2 BLE (optional — leave blank to auto-scan)
GALAXYFIT2_ADDRESS=

# Logging
LOG_LEVEL=INFO
