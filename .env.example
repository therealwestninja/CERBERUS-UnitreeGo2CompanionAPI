# CERBERUS — .env.example  (v3.1.0)
# Copy to .env and fill in your values.
# These override the corresponding settings in config/cerberus.yaml.

# ── Server ───────────────────────────────────────────────────────────────
CERBERUS_HOST=0.0.0.0
CERBERUS_PORT=8080
CERBERUS_DEV=false       # set true to enable hot-reload (development only)

# ── Robot connection ─────────────────────────────────────────────────────
# Override config/cerberus.yaml robot.transport
# GO2_TRANSPORT=mock       # mock | dds | webrtc

# DDS (Go2 EDU wired)
# GO2_NETWORK_INTERFACE=eth0

# WebRTC Wi-Fi (all models, no jailbreak)
# GO2_ROBOT_IP=192.168.8.1
# GO2_SERIAL_NUMBER=B42D2000XXXXXXXX
# GO2_WEBRTC_METHOD=local_sta    # ap | local_sta | remote
# GO2_WEBRTC_USERNAME=
# GO2_WEBRTC_PASSWORD=

# ── NLU / LLM fallback ───────────────────────────────────────────────────
# Required only if you want LLM-powered natural language commands.
# Rule-based NLU works without any API key.
CERBERUS_OPENAI_API_KEY=

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CERBERUS_CONFIG=config/cerberus.yaml
