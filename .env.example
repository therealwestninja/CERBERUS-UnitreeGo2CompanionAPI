# go2_platform/.env.example
# Copy to .env and fill in your values. Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────
GO2_HOST=0.0.0.0
GO2_PORT=8080
GO2_LOG_LEVEL=info              # debug | info | warn | error

# ── Mode ──────────────────────────────────────────────────────────────────
GO2_MODE=simulation             # simulation | hardware | hybrid
GO2_ROBOT_IP=192.168.12.1
GO2_ROBOT_MODEL=edu             # air | pro | edu

# ── Security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
GO2_SECRET_KEY=change-me-in-production-use-secrets-token-hex-32
GO2_API_TOKEN=                  # Bearer token for REST API (leave empty to disable auth)
GO2_ALLOWED_ORIGINS=*           # Comma-separated allowed CORS origins. Use * for dev only.

# ── Audit Log ─────────────────────────────────────────────────────────────
GO2_AUDIT_SECRET=change-me-audit-hmac-secret

# ── Plugins ───────────────────────────────────────────────────────────────
GO2_PLUGIN_DIR=plugins
GO2_PLUGIN_AUTO_LOAD=true

# ── Fleet ─────────────────────────────────────────────────────────────────
GO2_FLEET_ENABLED=false

# ── OTA Updates ───────────────────────────────────────────────────────────
GO2_OTA_REGISTRY_URL=
GO2_OTA_AUTO_CHECK=false

# ── External Integrations ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=              # For AI behavior generation in UI
BUTTPLUG_WS_URI=ws://localhost:12345
