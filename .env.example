# CERBERUS Environment Configuration
# ════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values for your deployment.
#   cp .env.example .env
#   nano .env
#
# Lines beginning with # are comments and are ignored.
# All values without a # are active defaults — change before deploying.
# ════════════════════════════════════════════════════════════════════════════


# ── Bridge mode (CHOOSE ONE) ─────────────────────────────────────────────────

# Software simulation — no robot required.
# All sensors are simulated; plugins and API work fully.
GO2_SIMULATION=true

# MuJoCo physics simulation (requires: pip install mujoco>=3.1.0)
# Set GO2_SIMULATION=true AND GO2_MUJOCO=true to activate.
# Model path: git clone https://github.com/unitreerobotics/unitree_mujoco.git
GO2_MUJOCO=false
# CERBERUS_MUJOCO_MODEL=unitree_mujoco/unitree_robots/go2/scene.xml

# ROS 2 bridge (requires: ROS 2 Humble, rclpy, unitree_ros2)
# Set GO2_SIMULATION=true AND GO2_ROS2=true to activate.
GO2_ROS2=false
# ROS2_NODE_NAME=cerberus_go2
# ROS2_NAMESPACE=/go2

# Real hardware (CycloneDDS — requires: unitree_sdk2_python)
# Set GO2_SIMULATION=false for real hardware mode.
# Find your interface: ip link show   (look for eth0, enp2s0, usb0, etc.)
GO2_NETWORK_INTERFACE=eth0


# ── Security ─────────────────────────────────────────────────────────────────

# API key — REQUIRED for real-hardware deployment.
# Generate a secure key:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# ⚠️  Without this set, ANY client on the network can control the robot.
# Leave empty in simulation if you don't need auth (convenient for dev).
CERBERUS_API_KEY=

# Allowed CORS origins for the REST API (comma-separated).
# Add your dashboard host if accessing from another machine.
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:5173


# ── API Server ───────────────────────────────────────────────────────────────

# Bind address — 0.0.0.0 for LAN access, 127.0.0.1 for localhost only.
GO2_API_HOST=0.0.0.0
GO2_API_PORT=8080

# Workers — keep at 1; CERBERUS uses a single asyncio event loop.
GO2_API_WORKERS=1


# ── Engine ───────────────────────────────────────────────────────────────────

# Tick rate in Hz.  60 Hz is the recommended default.
# Lower (30) for lower-power hardware.  Never exceed 200 Hz.
CERBERUS_HZ=60

# Watchdog heartbeat timeout — stop all motion if no heartbeat received.
# Increase if your network has high jitter.  Minimum: 0.5 s.
HEARTBEAT_TIMEOUT=5.0

# DDS SDK connection timeout per command (seconds).
# Increase on high-latency wireless links.
GO2_SDK_TIMEOUT=10.0


# ── Safety thresholds ────────────────────────────────────────────────────────
# These match the SafetyLimits defaults.  Uncomment to override.

# CERBERUS_MAX_VX=1.5          # m/s forward
# CERBERUS_MAX_VY=0.8          # m/s lateral
# CERBERUS_MAX_VYAW=2.0        # rad/s yaw
# CERBERUS_MAX_ROLL_DEG=35.0   # degrees before E-stop
# CERBERUS_MAX_PITCH_DEG=30.0  # degrees before E-stop
# CERBERUS_MIN_BODY_HEIGHT=0.20 # m
# CERBERUS_MAX_BODY_HEIGHT=0.55 # m
# CERBERUS_BATTERY_WARN_PCT=25  # LED amber below this
# CERBERUS_BATTERY_LOW_PCT=15   # reduce speed below this
# CERBERUS_BATTERY_CRIT_PCT=8   # E-stop below this


# ── Personality ───────────────────────────────────────────────────────────────
# Initial trait values [0.05–0.98].  These evolve slowly over sessions.
# Only used on first boot or if no session file exists.

PERSONALITY_ENERGY=0.7
PERSONALITY_FRIENDLINESS=0.8
PERSONALITY_CURIOSITY=0.6
PERSONALITY_LOYALTY=0.9
PERSONALITY_PLAYFULNESS=0.65


# ── Session persistence ──────────────────────────────────────────────────────

# Where to persist personality evolution across restarts.
CERBERUS_SESSION_FILE=logs/personality_session.json


# ── Plugins ──────────────────────────────────────────────────────────────────

# Colon-separated list of directories to search for plugins.
PLUGIN_DIRS=plugins

# Maximum consecutive tick errors before a plugin is auto-disabled.
PLUGIN_MAX_ERRORS=5


# ── Logging ──────────────────────────────────────────────────────────────────

# Python log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Safety audit log — every watchdog event is appended as JSON.
# This file is written per-event and is NOT lost on SIGKILL.
CERBERUS_AUDIT_LOG=logs/safety_audit.jsonl


# ── Voice NLU (optional — pip install cerberus-go2[voice]) ───────────────────

# Whisper model size.  Larger = more accurate, slower startup, more RAM.
#   tiny.en (39 MB) — fast, English-only, suitable for most commands
#   base.en (74 MB) — slightly better accuracy
#   small.en (244 MB) — good balance
#   medium.en (769 MB) — high accuracy, needs 4 GB+ RAM
#   large (1550 MB)  — best accuracy, GPU strongly recommended
CERBERUS_WHISPER_MODEL=tiny.en

# Microphone input device index or name.  Default: system default.
# List devices: python -c "import sounddevice as sd; print(sd.query_devices())"
# CERBERUS_VOICE_DEVICE=default

# Sample rate in Hz.  Whisper expects 16000 Hz.
CERBERUS_VOICE_SAMPLERATE=16000

# Voice activity detection threshold (RMS, 0.0–1.0).
# Increase in noisy environments.  Decrease for quiet/distant microphone.
CERBERUS_VOICE_THRESHOLD=0.02


# ── MuJoCo (optional — pip install cerberus-go2[mujoco]) ─────────────────────

# Path to the Go2 MuJoCo scene XML.
# Get it: git clone https://github.com/unitreerobotics/unitree_mujoco.git
# CERBERUS_MUJOCO_MODEL=unitree_mujoco/unitree_robots/go2/scene.xml
